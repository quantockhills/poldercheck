# Copy to .env and fill in. .env is gitignored.

# ---- LLM provider ----
# Poldercheck is provider-agnostic: set base_url + api_key + model, done.
#
# MVP setup (DeepSeek):
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=sk-...
POLDERCHECK_MODEL=deepseek-v4-pro          # all three agents use this
#
# Later setup (OpenRouter, when you want Claude/Qwen pushback models):
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_API_KEY=sk-or-...
# POLDERCHECK_POLITICAL_MODEL=anthropic/claude-sonnet-4-6
# POLDERCHECK_DATA_MODEL=qwen/qwen3-30b-a3b
# POLDERCHECK_SYNTHESIS_MODEL=anthropic/claude-sonnet-4-6

# ---- Data sources ----
MANIFESTO_API_KEY=your_manifesto_project_key_here   # free signup: https://manifesto-project.wzb.eu/signup

# ---- Langfuse observability (Step 13) ----
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
